# DB_TYPE: sqlite (local) | mongodb (Atlas / Vercel)
DB_TYPE=sqlite
DB_PATH=./data/app.db

# MongoDB Atlas (required when DB_TYPE=mongodb)
# Get from: Atlas Dashboard → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/gitlab_chat

ENCRYPTION_KEY=<64 char hex, run: openssl rand -hex 32>
JWT_SECRET=<long random string>
JWT_EXPIRES_IN=8h

CHAT_BOT_ENDPOINT=https://yourdomain.com/chat-callback
FRONTEND_URL=http://localhost:5173

PORT=3000
NODE_ENV=development
